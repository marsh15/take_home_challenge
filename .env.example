# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# Required: Serper API key for web search tool
SERPER_API_KEY=your-serper-api-key-here

# Required: At least one LLM provider API key
# Option A: Google Gemini (recommended — free tier available at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Option B: OpenAI (uncomment and set if using OpenAI instead)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Model selection (change based on your provider)
# For Gemini:  gemini/gemini-2.5-flash  or  gemini/gemini-1.5-flash
# For OpenAI:  gpt-4o-mini  or  gpt-4o
OPENAI_MODEL_NAME=gemini/gemini-2.5-flash
